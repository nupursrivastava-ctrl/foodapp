import os, uuid, boto3
from pathlib import Path

TMP_DIR = Path("/tmp/food_app")
TMP_DIR.mkdir(parents=True, exist_ok=True)

def save_temp(bytes_data: bytes, filename: str):
    fname = f"{uuid.uuid4().hex}_{filename}"
    path = TMP_DIR / fname
    with open(path, "wb") as f:
        f.write(bytes_data)
    return str(path)

def delete_local(path: str):
    try:
        os.remove(path)
    except Exception:
        pass

def upload_to_s3(local_path: str, remote_name: str):
    endpoint = os.getenv("S3_ENDPOINT")
    access = os.getenv("S3_ACCESS_KEY")
    secret = os.getenv("S3_SECRET_KEY")
    bucket = os.getenv("S3_BUCKET")
    if not endpoint or not access or not secret or not bucket:
        return None
    s3 = boto3.client("s3", aws_access_key_id=access, aws_secret_access_key=secret, endpoint_url=endpoint)
    key = f"uploads/{remote_name}"
    s3.upload_file(local_path, bucket, key)
    return key
