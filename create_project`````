from app.database import SessionLocal
from app.models import Meal
import datetime
from typing import Optional

def save_meal(payload: dict):
    db = SessionLocal()
    m = Meal(timestamp = datetime.datetime.fromisoformat(payload.get("timestamp")) if payload.get("timestamp") else datetime.datetime.utcnow(),
             items = payload.get("items", []),
             notes = payload.get("notes"))
    db.add(m)
    db.commit()
    db.refresh(m)
    db.close()
    return m

def get_log(date: Optional[str] = None):
    db = SessionLocal()
    q = db.query(Meal).order_by(Meal.timestamp.desc()).limit(50)
    if date:
        # simple filter by date prefix
        start = datetime.datetime.fromisoformat(date)
        end = start + datetime.timedelta(days=1)
        q = db.query(Meal).filter(Meal.timestamp >= start, Meal.timestamp < end).order_by(Meal.timestamp.desc())
    meals = q.all()
    db.close()
    return {"meals": [ {"id":m.id, "timestamp":m.timestamp.isoformat(), "items":m.items} for m in meals ]}
