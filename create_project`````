import axios from 'axios'

const API = axios.create({
  baseURL: process.env.NEXT_PUBLIC_API_URL || 'http://localhost:8000',
  timeout: 60000
})

export async function processPhoto(file: File) {
  const form = new FormData()
  form.append('photo', file)
  const res = await API.post('/process-photo', form, {
    headers: { 'Content-Type': 'multipart/form-data' }
  })
  return res.data
}

export async function saveMeal(meal: any) {
  const res = await API.post('/save-meal', meal)
  return res.data
}

export async function getLog(date?: string) {
  const res = await API.get('/log', { params: { date } })
  return res.data
}

export default API
